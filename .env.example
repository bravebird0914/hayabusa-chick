# 使用するLLMプロバイダのAPIキーをここに設定してください。
# agent.py の中で os.getenv("...") を使って読み込む想定です。
# 必要なものだけコメントを外して使ってください(複数設定してもOK)。

# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
# GOOGLE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# --- サンプル実装(OpenAI)用のモデル設定 ---
# 使うモデルを変えたい場合はコメントを外して指定してください(未設定なら gpt-5.6)。
# OPENAI_MODEL=gpt-5.6

# reasoning_effort は GPT-5 系のみ対応のパラメータです(none/low/medium/high/xhigh)。
# GPT-5 以外のモデル(gpt-4o など)を使う場合は、下記を「値なし」にして無効化してください。
# OPENAI_REASONING_EFFORT=none
